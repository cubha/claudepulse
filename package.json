{
  "name": "claude-code-gauge",
  "displayName": "Claude Code Gauge",
  "description": "Real-time Claude Code rate limit dashboard. Track 5h/7d usage, burn rate & safe-until predictions in StatusBar, Sidebar and Dashboard.",
  "version": "0.1.2",
  "publisher": "cubha",
  "icon": "media/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cubha/claude-code-gauge.git"
  },
  "homepage": "https://github.com/cubha/claude-code-gauge#readme",
  "bugs": {
    "url": "https://github.com/cubha/claude-code-gauge/issues"
  },
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "claude-max",
    "anthropic",
    "rate-limit",
    "usage",
    "dashboard",
    "monitor",
    "burn-rate"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeCodeGauge",
          "title": "Claude Code Gauge",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "claudeCodeGauge": [
        {
          "type": "webview",
          "id": "claudeCodeGauge.sidebar",
          "name": "Claude Code Gauge"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeCodeGauge.openDashboard",
        "title": "Claude Code Gauge: Open Dashboard"
      },
      {
        "command": "claudeCodeGauge.refresh",
        "title": "Claude Code Gauge: Refresh"
      },
      {
        "command": "claudeCodeGauge.login",
        "title": "Claude Code Gauge: Login with Claude"
      }
    ],
    "configuration": {
      "title": "Claude Code Gauge",
      "properties": {
        "claudeCodeGauge.credentialsPath": {
          "type": "string",
          "default": "",
          "description": "Path to Claude Code credentials file. Leave empty to use default (~/.claude/.credentials.json)."
        },
        "claudeCodeGauge.pollIntervalMs": {
          "type": "number",
          "default": 300000,
          "description": "How often to poll the Anthropic API for rate limit data (ms). Default: 300000 (5 min)."
        },
        "claudeCodeGauge.utilizationWarnThreshold": {
          "type": "number",
          "default": 0.8,
          "minimum": 0,
          "maximum": 1,
          "description": "Show a warning when utilization exceeds this value (0–1). Default: 0.8 (80%)."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs && tsc --noEmit",
    "watch": "node esbuild.config.mjs --watch",
    "lint": "eslint src --ext ts",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:integration": "vscode-test",
    "package": "vsce package --no-dependencies",
    "publish:vscode": "vsce publish --no-dependencies",
    "publish:ovsx": "ovsx publish --no-dependencies"
  },
  "dependencies": {
    "chart.js": "^4.4.0",
    "vscode-messenger": "^0.5.0",
    "vscode-messenger-common": "^0.5.0",
    "vscode-messenger-webview": "^0.5.0"
  },
  "devDependencies": {
    "@types/chokidar": "^1.7.5",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/test-electron": "^2.3.9",
    "@vscode/vsce": "^2.24.0",
    "chokidar": "^3.6.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.57.0",
    "ovsx": "^0.9.0",
    "prettier": "^3.2.0",
    "sharp": "^0.34.5",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
