{
  "name": "claudepulse",
  "displayName": "Claudepulse — Claude Rate Limit Dashboard",
  "description": "Claude Max 플랜 Rate Limit 실시간 모니터링. 세션(5h)·주간(7d) 사용률, Burn Rate, Safe Until 예측을 StatusBar·Sidebar·Dashboard에 표시.",
  "version": "0.1.5",
  "publisher": "cubha",
  "icon": "media/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cubha/claudepulse.git"
  },
  "homepage": "https://github.com/cubha/claudepulse#readme",
  "bugs": {
    "url": "https://github.com/cubha/claudepulse/issues"
  },
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "rate-limit",
    "usage",
    "dashboard",
    "monitor"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudepulse",
          "title": "Claudepulse",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "claudepulse": [
        {
          "type": "webview",
          "id": "claudepulse.sidebar",
          "name": "Rate Limits"
        }
      ]
    },
    "commands": [
      {
        "command": "claudepulse.openDashboard",
        "title": "Claudepulse: Open Dashboard"
      },
      {
        "command": "claudepulse.refresh",
        "title": "Claudepulse: Refresh"
      },
      {
        "command": "claudepulse.login",
        "title": "Claudepulse: Login with Claude"
      }
    ],
    "configuration": {
      "title": "Claudepulse",
      "properties": {
        "claudepulse.credentialsPath": {
          "type": "string",
          "default": "",
          "description": "Path to Claude Code credentials file. Leave empty to use default (~/.claude/.credentials.json)."
        },
        "claudepulse.pollIntervalMs": {
          "type": "number",
          "default": 300000,
          "description": "How often to poll the Anthropic API for rate limit data (ms). Default: 300000 (5 min)."
        },
        "claudepulse.utilizationWarnThreshold": {
          "type": "number",
          "default": 0.8,
          "minimum": 0,
          "maximum": 1,
          "description": "Show a warning when utilization exceeds this value (0–1). Default: 0.8 (80%)."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs && tsc --noEmit",
    "watch": "node esbuild.config.mjs --watch",
    "lint": "eslint src --ext ts",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:integration": "vscode-test",
    "package": "vsce package --no-dependencies",
    "publish:vscode": "vsce publish --no-dependencies",
    "publish:ovsx": "ovsx publish --no-dependencies"
  },
  "dependencies": {
    "chart.js": "^4.4.0",
    "vscode-messenger": "^0.5.0",
    "vscode-messenger-common": "^0.5.0",
    "vscode-messenger-webview": "^0.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/test-electron": "^2.3.9",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.57.0",
    "ovsx": "^0.9.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
